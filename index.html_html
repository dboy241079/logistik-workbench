  <!-- Warenstamm: wird lazy geladen in dieses Pane -->
  <div class="tab-pane fade" id="goods" role="tabpanel" aria-labelledby="tab-goods">
    <div class="p-3 text-muted">Lade Warenstamm…</div>
  </div>

  
  <div class="tab-pane fade" id="inbound" role="tabpanel"></div>
<div class="tab-pane fade" id="outbound" role="tabpanel"></div>

