<li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#cmr"
   
            type="button" role="tab"><i class="bi bi-file-earmark-richtext"></i>
              <span>CMR</span></button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#exports"
              type="button" role="tab"><i class="bi bi-filetype-csv"></i>
