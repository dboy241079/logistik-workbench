            </button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#drivers"
              data-url="/LKW/fahrer_ubersicht.html" data-module="/LKW/js/fahrer_ubersicht.js"
              data-init="initFahrerUebersicht" type="button" role="tab"><i class="bi bi-truck"></i>
              <span>Fahrer</span></button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#goods"
              data-url="/LKW/sachnummern.html" data-module="/LKW/js/sachnummern.js"
              data-init="initSachnummern" type="button" role="tab"><i class="bi bi-box"></i>
              <span>Warenstamm</span></button></li>
